from PIL import Image, ImageDraw, ImageFont
import time

def resize_image(image, new_width=50):
    width, height = image.size
    aspect_ratio = height / width
    new_height = int(new_width * aspect_ratio * 0.55)
    return image.resize((new_width, new_height))

def resize_text_image(image, new_width=60):
    width, height = image.size
    aspect_ratio = height / width
    new_height = int(new_width * aspect_ratio)
    return image.resize((new_width, new_height))

def show_image_in_console(path, char="█", width=60):
    try:
        img = Image.open(path).convert("RGB")
    except Exception as e:
        print("❌ Error al abrir la imagen:", e)
        return
    img = resize_image(img, new_width=width)
    for y in range(img.height):
        line = ""
        for x in range(img.width):
            r, g, b = img.getpixel((x, y))
            line += f"\033[38;2;{r};{g};{b}m{char}\033[0m"
        print(line)

def show_pil_image_in_console(img, char="█"):
    for y in range(img.height):
        line = ""
        for x in range(img.width):
            r, g, b = img.getpixel((x, y))
            line += f"\033[38;2;{r};{g};{b}m{char}\033[0m"
        print(line)

def show_text_as_ascii(text, font_path, font_size=20):
    img = create_text_image(text, font_path, font_size=font_size, bg=(0, 0, 0))
    img = resize_text_image(img, new_width=60)
    show_pil_image_in_console(img, char="█")

def create_text_image(text, font_path, font_size=16, color=(255, 255, 255), bg=(0, 0, 0)):
    font = ImageFont.truetype(font_path, font_size)
    dummy_img = Image.new("RGB", (1, 1), bg)
    draw = ImageDraw.Draw(dummy_img)
    bbox = draw.textbbox((0, 0), text, font=font)
    text_width = bbox[2] - bbox[0]
    text_height = bbox[3] - bbox[1]
    img = Image.new("RGB", (text_width + 10, text_height + 10), bg)
    draw = ImageDraw.Draw(img)
    draw.text((5, 5), text, font=font, fill=color)
    return img

